{# Nested Components ------------------------------------------------------------------------------------------------------------------- #}

{% from "snippets/loopAttrs.njk" import loopAttrs %}
{% from "components/icon.njk" import icon %}

{# Macro ------------------------------------------------------------------------------------------------------------------------------- #}

{% macro button(props={},attrs={}) %}

{# Values ----------- #}

{% set buttonStyles = {
    shared: "transition-transform decoration-[1.5px] underline-offset-4",
    button: {
        styles: "hover:scale-[1.05] active:scale-[.99] h-fit hover:underline border backdrop-blur-base",
        sizes: {
            sm: "text-button-sm min-w-tube-sm min-h-tube-sm rounded-sm gap-4 px-6",
            base: "text-button-base min-w-tube-base min-h-tube-base rounded-base gap-4 px-7",
            lg: "text-button-lg min-w-tube-base min-h-tube-base rounded-base gap-5 px-7 md:min-w-tube-lg md:min-h-tube-lg md:rounded-lg md:gap-7 md:px-9"
        },
        variants: {
            neutral: {
                styles:"border-neutral-light bg-neutral hover:bg-action-lighter hover:border-action-light",
                on: "bg-neutral-light!"
            },
            action: {
                styles:"border-action-light bg-action-light hover:bg-action hover:border-neutral-lighter hover:text-surface",
                on:"bg-neutral-light!"
            }
        }
    },
    link: {
        styles: "",
        on: "",
        sizes: {
            inherit: "",
            base: "text-body-base gap-xs",
            sm: "text-body-sm gap-2xs",
            lg: "text-body-lg gap-xs"
        },
        variants: {
            action:{
                styles:"text-action underline hover:no-underline",
                on:""
            },
            neutral: {
                styles:"text-neutral no-underline hover:underline",
                on:""
            }
        }
    }
} %}

{# ------------------------------------------------------------------------------------------------------------------------------------- #}

<span data-button
        class="inline-flex shrink-0 disabled:opacity-60
        {% if props.type === "button" %}
            {{ buttonWrapperStyles.shared }}
            {{ buttonWrapperStyles.sizes[props.size] }}
            {{ buttonWrapperStyles.variants[props.variant] }}
        {% endif %}
        {{ attrs.class }}
        {% if attrs.disabled %}pointer-events-none{% endif %}">

    <{% if attrs.href %}a{% else %}button{% endif %}
        {{ loopAttrs(attrs) }}
        {% if props.toggleValue %}
            {% if not props.label %}:aria-label="{{ props.toggleValue}} ? '{{ props.tooltip.on }}' : '{{ props.tooltip.off }}'"{% endif %}
            :title="{{ props.toggleValue }} ? '{{ props.tooltip.on }}' : '{{ props.tooltip.off }}'"
        {% else %}
            {% if props.tooltip %}
                {% if not props.label %}aria-label="{{ props.tooltip }}"{% endif %}
                title="{{ props.tooltip }}"
            {% endif %}
        {% endif %}
        class="w-full flex justify-center items-center cursor-pointer
            {{ buttonStyles[props.type].styles }}
            {{ buttonStyles[props.type].sizes[props.size] }}
            {{ buttonStyles[props.type].variants[props.variant].styles }}
            {{ buttonStyles.shared }}"
            {% if props.toggleValue %}
                {% if buttonStyles[props.type].variants[props.variant].on %}
                    :class="{{ props.toggleValue }} && '{{ buttonStyles[props.type].variants[props.variant].on }}'"
                {% endif %}
        {% endif %}>

        {% if props.icon or props.label %}
            <span class="flex items-center justify-center pointer-events-none gap-inherit {% if props.iconPosition === "end" %}flex-row-reverse{% endif %}">
                {% if props.toggleValue %}
                    {% if props.icon %}
                        {% set show %}{{ props.toggleValue }} == false {% endset %}
                        {{ icon({glyph:props.icon.off if props.icon.off else props.icon }, {"x-show":show}) }}
                        {% set show %}{{ props.toggleValue }} == true {% endset %}
                        {{ icon({glyph:props.icon.on if props.icon.off else props.icon }, {"x-show":show, "x-cloak": true}) }}
                    {% endif %}
                    {% if props.label %}
                        <span x-show="!{{ props.toggleValue }}">{{ props.label.off if props.label.off else props.label }}</span>
                        <span x-show="{{ props.toggleValue }}" x-cloak>{{ props.label.on if props.label.on else props.label }}</span>
                    {% endif %}
                {% else %}
                    {{ icon({glyph:props.icon}) if props.icon }}
                    {% if props.label %}
                        <span>{{ props.label }}</span>
                    {%- endif -%}
                {% endif %}
            </span>
        {% else %}
            {{ caller() | safe if caller }}
        {%- endif -%}

    </{% if attrs.href %}a{% else %}button{% endif %}>
</span>

{% endmacro %}

{# Component Documentation ------------------------------------------------------------------------------------------------------------- #}

{% set buttonMeta = {
    args: '{{ button(
    props={
        label: "",
        icon: "",
        tooltip: ""
        type: "button | link",
        size: "base | lg | sm | inherit",
        toggleValue: "",
        iconPosition: "start | end"
    },
    attrs={}
) }}',
description: "
- Tag defaults to `button` unless you provide an `attrs.href`, then it'll be an `a` tag.
- Optionally you can use `{% call %}` to give custom inner HTML.
- `props.toggleValue` is the `x-data` value that the button looks for to determine its on/off state. If you use this property, the `button` expects the `props.icon` and `props.label` values to be objects with `on` and `off` keys.
"
} %}
