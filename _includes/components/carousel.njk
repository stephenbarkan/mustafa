{# Nested Components ------------------------------------------------------------------------------------------------------------------- #}

{% from "snippets/loopAttrs.njk" import loopAttrs %}
{% from "components/button.njk" import button %}
{% from "components/figure.njk" import figure %}
{% from "components/icon.njk" import icon %}

{# Values ------------------------------------------------------------------------------------------------------------------------------ #}

{# Theme styles ----------- #}

{% set carouselStyles = "gap-8" %}

{% set slideStyles = "gap-8 overflow-hidden" %}
{% set slideImageStyles = "border border-neutral-lighter bg-neutral rounded-lg overflow-hidden" %}
{% set slideCaptionStyles = "text-center text-body-base" %}

{% set controlsStyles = "gap-6 justify-between items-center" %}

{% set indicatorRowStyles = "min-w-tube-sm min-h-tube-sm rounded-sm px-3 xs:px-4 bg-neutral backdrop-blur-base border-neutral-lighter border" %}
{% set indicatorStyles = "size-3 @md:size-2.5 border border-neutral-light hover:bg-(--color-neutral) rounded-full" %}
{% set indicatorCheckedStyles = "bg-action!" %}

{% set buttonProps = {
    type: "button",
    size: "sm",
    variant: "neutral"
} %}
{% set buttonStyles = "grow" %}

{# Macro ------------------------------------------------------------------------------------------------------------------------------- #}

{% macro carousel(props={}, attrs={}) %}

<div data-carousel
    role="group"
    aria-roledescription="carousel"
    x-id="['carousel-slide', 'carousel-indicator']"
    x-data="{
        currentSlideIndex: 1,
        init() {
            this.$nextTick(() => this.select(1))
        },
        select(i) {
            this.currentSlideIndex = i;
        },
        isSelected(i) {
            return this.currentSlideIndex === i
        },
        stopVideos() {
            document.querySelectorAll('iframe').forEach(v => { v.src = v.src });
            document.querySelectorAll('video').forEach(v => { v.pause() });
        },
        previous() {
            if (this.currentSlideIndex > 1) {
                this.currentSlideIndex = this.currentSlideIndex - 1
            } else {
                // If it's the first slide, go to the last slide
                this.currentSlideIndex = {{ props.slides | length }}
            }
            this.stopVideos()
        },
        next() {
            if (this.currentSlideIndex < {{ props.slides | length }}) {
                this.currentSlideIndex = this.currentSlideIndex + 1
            } else {
                // If it's the last slide, go to the first slide
                this.currentSlideIndex = 1
            }
            this.stopVideos()
        },
    }"
    {{ loopAttrs(attrs) }}
    class="@container relative w-full flex flex-col grow {{ attrs.class }} {{ carouselStyles }}">

{# slides ------------------ #}

    <div
        aria-atomic="false"
        aria-live="polite"
        tabindex="0"
        {% if props.indicators %}
            aria-label="slides"
        {% endif %}
        class="relative grid overflow-hidden grid-overlap grow">

        {# loading svg #}
        <div data-loader class="animate-spin text-neutral text-body-lg place-self-center z-(--z-lowered)">{{ icon({icon:"progress_activity"}) }}</div>

        {# slide #}
        {% for item in props.slides %}
            <div
                x-data="{ id: $id('carousel-slide', {{ loop.index }})}"
                aria-label="{{ loop.index }} of {{ loop.length }}"
                aria-roledescription="slide"
                {% if props.indicators %}
                    aria-labelledby="carousel-indicator-{{ loop.index }}"
                    role="tabpanel"
                {% else %}
                    role="group"
                {% endif %}
                :id="id"
                :class="currentSlideIndex !== {{ loop.index }} && 'invisible opacity-0'"
                class="flex w-full transition duration-500 transition-discrete"
                {{ loopAttrs(attrs) }}>

                {# slide macro #}
                {{ props.macro(item,{class:"w-full"}) }}
            </div>
        {% endfor %}

    </div>

{# controls bar ------------------ #}

    {% if props.slides.length > 1 %}
        <div class="flex {{ controlsStyles }}">

            {# previous button #}
            {{ button(
                props={
                    type: buttonProps.type,
                    size: buttonProps.size,
                    variant: buttonProps.variant,
                    icon: "arrow_back",
                    tooltip:"Previous slide"
                },
                attrs={
                    "@click": "previous()",
                    "class": buttonStyles
                }
            ) }}

            {# tablist #}
            {% if props.indicators %}
                <div
                    role="tablist"
                    @keydown.right.prevent.stop="$focus.wrap().next()"
                    @keydown.left.prevent.stop="$focus.wrap().prev()"
                    @keydown.home.prevent.stop="$focus.first()"
                    @keydown.page-up.prevent.stop="$focus.first()"
                    @keydown.end.prevent.stop="$focus.last()"
                    @keydown.page-down.prevent.stop="$focus.last()"
                    aria-label="Choose slide to display"
                    class="flex self-center justify-self-center justify-center items-center overflow-x-auto {{ indicatorRowStyles }}">
                    {% for slide in props.slides %}
                        <button
                            :id="$id('carousel-indicator', {{ loop.index }})"
                            role="tab"
                            aria-label="Slide {{ loop.index }}"
                            :aria-selected="isSelected({{ loop.index }})"
                            :aria-controls="$id('carousel-slide', {{ loop.index }})"
                            @focus="select({{ loop.index }})"
                            :tabindex="isSelected({{ loop.index }}) ? 0 : -1"
                            class="grid place-content-center min-w-6 aspect-square">
                            <div
                                :class="isSelected({{ loop.index }}) && '{{ indicatorCheckedStyles }}'"
                                class="flex items-center {{ indicatorStyles }}">
                                {{ props.data.label }}
                            </div>
                        </button>
                    {% endfor %}
                </div>
            {% endif %}

            {# next button #}
            {{ button(
                props={
                    type: buttonProps.type,
                    size: buttonProps.size,
                    variant: buttonProps.variant,
                    icon: "arrow_forward",
                    tooltip: "Next slide",
                    iconPosition: "end"
                },
                attrs={
                    "@click": "next()",
                    "class": buttonStyles
                }
            ) }}

        </div>
    {% endif %}
</div>

{% endmacro %}



{# Component Documentation ------------------------------------------------------------------------------------------------------------- #}

{% set carouselMeta = {
    args: '{% call carousel(
    props={
        slides: [],
        indicators: true | false
    },
    attrs={}
) %}
    {% from "components/carousel.njk" import carouselSlide %}
    {% for slide in slides %}
        {% call carouselSlide({loop:loop}) %}
            {# slide content #}
        {% endcall %}
    {% endfor %}
{% endcall %}',
description: ""
} %}
